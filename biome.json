{
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/worker-configuration.d.ts",
      "!**/node_modules",
      "!**/dist",
      "!**/.turbo",
      "!**/build",
      "!**/.wrangler",
      "!**/.vscode"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf",
    "includes": ["**/*.ts", "**/*.js", "**/*.json"]
  },
  "linter": {
    "enabled": true,
    "includes": ["**/*.ts", "**/*.js", "**/*.json"],
    "rules": {
      "recommended": true,
      "a11y": { "recommended": true },
      "style": {
        "useBlockStatements": "error",
        "noParameterProperties": "error",
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "strictCase": true,
            "requireAscii": true,
            "filenameCases": ["kebab-case"]
          }
        }
      },
      "complexity": {
        "noExcessiveLinesPerFunction": {
          "level": "error",
          "options": {
            "maxLines": 100,
            "skipBlankLines": true,
            "skipIifes": false
          }
        },
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": { "maxAllowedComplexity": 100 }
        }
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "error"
      },
      "performance": { "noAccumulatingSpread": "error" },
      "nursery": {}
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "parser": {
      "allowComments": true,
      "allowTrailingCommas": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "recommended": true,
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.d.ts"],
      "linter": {
        "rules": { "correctness": { "noUnusedVariables": "off" } }
      }
    },
    {
      "includes": ["**/*.test.ts", "**/*.spec.ts", "tests/**/*"],
      "linter": {
        "rules": {
          "style": { "noNonNullAssertion": "off" },
          "suspicious": { "noExplicitAny": "off" },
          "complexity": { "noExcessiveCognitiveComplexity": "off" }
        }
      }
    },
    {
      "includes": ["**/*.jsonc", "**/wrangler.jsonc"],
      "json": {
        "parser": {
          "allowComments": true,
          "allowTrailingCommas": true
        }
      }
    }
  ]
}
